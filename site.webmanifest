{
  "name": "Doctordle",
  "short_name": "Doctordle",
  "description": "Doctordle is a diagnosis guessing game built around daily clinical cases.",
  "start_url": "/",
  "scope": "/",
  "display": "standalone",
  "display_override": ["standalone", "minimal-ui"],
  "orientation": "portrait",
